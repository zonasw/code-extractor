{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "code-extractor",
  "version": "0.0.4",
  "identifier": "com.administrator.code-extractor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeExtractor",
        "width": 1200,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zonasw/code-extractor/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxMDZFQUMwRjBGMDA0MUEKUldRYUJQRHd3T29Ha2Uya3hVRmt0RWVQbjAwU2VqZVpxTWpGcmRWV0RwOEp6c0hjZ0docXF1amgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
